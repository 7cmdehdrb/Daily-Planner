{
  "expo": {
    "name": "하루결",
    "slug": "cplan",
    "scheme": "cplan",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/234da541-868e-4ab0-9e70-7e067af34fbb"
    },
    "userInterfaceStyle": "light",
