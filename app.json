{
  "expo": {
    "name": "하루결",
    "slug": "cplan",
    "scheme": "cplan",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.harugyeol.app",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "234da541-868e-4ab0-9e70-7e067af34fbb"
      }
    }
  }
}
